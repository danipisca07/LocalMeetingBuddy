DEEPGRAM_API_KEY=your_deepgram_api_key

ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL_ID=claude-sonnet-4-5 # Find using scripts/list-claude-models.js
CLAUDE_MAX_TOKENS=1024

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL_ID=openai/gpt-oss-20b
GROQ_MAX_TOKENS=1024

# Audio Device Configuration (run check-audio.js to get device IDs)
AUDIO_DEVICE_ID_SYSTEM=<your-loopback-device-id>
AUDIO_DEVICE_ID_MIC=<your-microphone-id>

# Transcription Configuration
# Provider: 'deepgram' (cloud, default) or 'local' (fully on-device, no API key needed)
TRANSCRIPTION_PROVIDER=deepgram
DEEPGRAM_LANGUAGE=it

# Local provider settings (used when TRANSCRIPTION_PROVIDER=local)
# Whisper model size: tiny | base | small | medium (bigger = better Italian, slower)
LOCAL_WHISPER_MODEL=base
# Language override; falls back to DEEPGRAM_LANGUAGE, then 'it'
LOCAL_TRANSCRIPTION_LANGUAGE=it
# Where models are downloaded/cached (default: ~/.meetingtwin/models)
#LOCAL_TRANSCRIPTION_MODELS_DIR=
# Speaker diarization: cosine similarity threshold for matching an existing speaker (0-1)
LOCAL_SPEAKER_THRESHOLD=0.55
# Voice activity detection sensitivity (0-1)
LOCAL_VAD_THRESHOLD=0.5

SKIP_LLM=false
